# Database
DB_NAME=moaju
DB_USERNAME=moaju_user
DB_PASSWORD=

# JWT (Base64, 64바이트 이상)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# CORS — EC2 퍼블릭 IP 또는 도메인
CORS_ALLOWED_ORIGINS=http://your-ec2-public-ip

# Cookie (HTTPS 없으면 false)
COOKIE_SECURE=false

# 한국투자증권 API
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Gmail SMTP (알람 메일 발송용, 앱 비밀번호 필요 — 공백 없이 16자)
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=

# Claude API (AI 시장 요약용)
ANTHROPIC_API_KEY=

